# App runtime env (Expo public)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_APP_SCHEME=spino

# Google Play products
EXPO_PUBLIC_GOOGLE_PLAY_PRODUCT_ID_MONTHLY=
EXPO_PUBLIC_GOOGLE_PLAY_PRODUCT_ID_YEARLY=
EXPO_PUBLIC_GOOGLE_PLAY_ANDROID_PACKAGE_NAME=com.spino.mobile

# Supabase Edge Function secrets (set in Supabase, not in app env)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_PLAY_ANDROID_PACKAGE_NAME=com.spino.mobile (defaults to app package if not set)
# GOOGLE_PLAY_ALLOWED_PACKAGE_NAMES=com.spino.mobile,com.spino.mobile.beta (comma-separated; verify-google-play-purchase only accepts these)com.spino.mobile (defaults to this if not set)
# GOOGLE_PLAY_ALLOWED_PACKAGE_NAMES=com.spino.mobile,com.spino.mobile.beta (comma-separated; edge function accepts only these)
